{
  "metadata": [
    {
      "src": [
        {
          "src": "../src",
          "files": ["Be.Windows.Forms.HexBox/bin/Release/net10.0-windows/Be.Windows.Forms.HexBox.dll"]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["*.md", "toc.yml"]
      }
    ],
    "resource": [
      {
        "files": ["../images/**"],
        "dest": "images"
      }
    ],
    "output": "_site",
    "globalMetadata": {
      "_appName": "HexBox",
      "_appTitle": "HexBox API Reference",
      "_enableSearch": true
    }
  }
}
